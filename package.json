{
  "name": "@bagdevich/gitkey",
  "version": "0.2.2",
  "description": "CLI for managing Git SSH profiles, keys and repo remotes",
  "type": "module",
  "bin": {
    "gitkey": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "git",
    "ssh",
    "ssh-key",
    "cli",
    "github",
    "bitbucket",
    "macos"
  ],
  "author": "Vitali Bahadzevich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bagdevich/gitkey.git"
  },
  "bugs": {
    "url": "https://github.com/bagdevich/gitkey/issues"
  },
  "homepage": "https://github.com/bagdevich/gitkey#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
